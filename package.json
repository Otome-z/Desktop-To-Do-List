{
  "name": "desktop-to-do-list",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/main/main.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron -r ts-node/register ./src/main/main.ts\"",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer && electron-builder",
    "preview": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "idb": "^8.0.3",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@types/electron": "^1.6.12",
    "@types/node": "^25.3.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "concurrently": "^9.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4",
    "ts-node": "^10.9.1"
  },
  "build": {
    "appId": "com.example.representative-tasks",
    "files": ["dist/**/*", "package.json"],
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": ["nsis"]
    }
  }
}
